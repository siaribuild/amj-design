# Dependencies — reinstalled from package-lock.json on each build.
# (Committing node_modules breaks Linux CI/Vercel: Windows files lose the
#  executable bit, so node_modules/.bin/vite fails with "Permission denied".)
node_modules/

# Build output — regenerated by `vite build`
dist/
dist-ssr/

# Generated Sanity import (regenerate with `npm run sanity:ndjson`)
sanity/catalogue.ndjson

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Env files
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
Thumbs.db
*.local

# Vercel
.vercel/

# Wrangler / Cloudflare local state (local D1, KV, R2, caches)
.wrangler/
.codex-tmp/

# Playwright E2E artifacts
playwright-report/
test-results/
coverage/
